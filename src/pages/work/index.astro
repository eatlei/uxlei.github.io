---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/utils";

const works = (await getCollection("work", ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<BaseLayout title="Work" description="精选设计作品">
  <section class="mx-auto max-w-6xl px-6 pt-20 pb-12 md:pt-28">
    <h1 class="font-display text-2xl">Work</h1>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-24 grid grid-cols-1 md:grid-cols-12 gap-x-8 gap-y-16">
    {works.map((w, i) => {
      const pattern = i % 3;
      const span = pattern === 0 ? "md:col-span-12" : pattern === 1 ? "md:col-span-7" : "md:col-span-5";
      const offset = pattern === 2 ? "md:mt-12" : "";
      return (
        <a href={withBase(`/work/${w.id}`)} class={`group block ${span} ${offset}`}>
          <div class="aspect-[16/10] rounded-md overflow-hidden bg-[color:var(--rule)] mb-5 relative">
            {w.data.cover ? (
              <img src={w.data.cover} alt={w.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center font-display text-5xl text-[color:var(--muted)]">
                {w.data.title.slice(0, 2)}
              </div>
            )}
          </div>
          <div class="flex items-baseline justify-between gap-4">
            <h2 class="font-display text-2xl group-hover:text-[color:var(--color-accent)] transition-colors">
              {w.data.title}
            </h2>
            <span class="font-mono text-xs text-[color:var(--muted)] shrink-0">{w.data.year}</span>
          </div>
          <p class="mt-2 text-[color:var(--muted)]">{w.data.summary}</p>
          {w.data.tags.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-2 text-xs">
              {w.data.tags.map((t) => (
                <li class="px-2 py-0.5 rounded-full border border-[color:var(--rule)] text-[color:var(--muted)]">{t}</li>
              ))}
            </ul>
          )}
        </a>
      );
    })}
    {works.length === 0 && (
      <p class="md:col-span-12 text-[color:var(--muted)]">作品集还在整理中。</p>
    )}
  </section>
</BaseLayout>
